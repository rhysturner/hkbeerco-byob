REMOTE_USER=user
REMOTE_HOST=example.com
REMOTE_DIR=/var/www/html
REMOTE_NAME=index.html
SSH_PORT=22
SSH_KEY=~/.ssh/your-key
SOURCE_FILE=byob-boss-invite.html
ASSET_DIRS="images fonts promo video qr BAB852 HJT852 HND852 SMB852 KTH852 VIR852"
EXTRA_FILES="virtual-code.html"
REMOTE_FILE_CHMOD=644
REMOTE_DIR_CHMOD=755
SSH_CONTROL_MASTER=1
SSH_CONTROL_PERSIST=10m
# SSH_CONTROL_PATH can be left default; set only if you need a custom socket path.
# SSH_CONTROL_PATH=~/.ssh/cm-%r@%h:%p

# Dev (brrrr.app) promo route config
CONFIGURE_PROMO_ROUTE=1
REMOTE_NGINX_SITE=/etc/nginx/sites-available/brrrr.app
PROMO_ROUTE_PREFIX=/hkbeerco/byob/promo/
PROMO_ROUTE_FALLBACK=/hkbeerco/byob/promo/index.html
PROMO_ROUTE_AUTH_OFF=1
PROMO_AUTH_ENABLE=0
PROMO_AUTH_REALM="Promo Redemption"
PROMO_AUTH_USER_FILE=/etc/nginx/.htpasswd_promo
# When PROMO_AUTH_ENABLE=1, auth settings above are applied and auth_off is ignored.
# Create auth file on server (example):
# sudo htpasswd -c /etc/nginx/.htpasswd_promo your-username
PROMO_ROUTE_STRICT=0

# Post-deploy promo route verification
VERIFY_PROMO_ROUTE=1
VERIFY_PROMO_BASE_URL=https://brrrr.app/hkbeerco/byob/promo
VERIFY_PROMO_CODE=BAB852
VERIFY_PROMO_EXPECT="Thank you! Beer redeemed."
VERIFY_PROMO_STRICT=0